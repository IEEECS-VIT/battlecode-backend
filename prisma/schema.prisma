generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String           @id
  name             String
  regNo            String           @unique
  username         String?          @unique
  role             Role             @default(PLAYER)
  eventScore       Int              @default(0)
  currentRound     Int              @default(0)
  round2Role       Round2Role?
  hackAttempts     HackAttempt[]    @relation("HackerAttempts")
  hackedAttempts   HackAttempt[]    @relation("TargetAttempts")
  lockedSolutions  LockedSolution[]
  matchesAsPlayerA Match[]          @relation("PlayerAMatches")
  matchesAsPlayerB Match[]          @relation("PlayerBMatches")
  matchesAsWinner  Match[]          @relation("WinnerMatches")
  submissions      Submission[]
}

model Round {
  roundNumber Int          @id
  status      RoundStatus  @default(LOCKED)
  problems    Problem[]
  submissions Submission[]
}

model Problem {
  id                 String           @id @default(uuid())
  title              String           @unique
  description        String
  difficulty         Difficulty
  constraints        String[]
  hints              String[]         @default([])
  boilerplate        Json?
  sampleTestCases    Json
  hiddenTestCases    Json
  avgTimeComplexity  String?
  avgSpaceComplexity String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  roundId            Int
  hackAttempts       HackAttempt[]
  lockedSolutions    LockedSolution[]
  round              Round            @relation(fields: [roundId], references: [roundNumber])
  submissions        Submission[]
  categories         Category[]       @relation("ProblemCategories")
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  problems Problem[] @relation("ProblemCategories")
}

model Submission {
  id              String           @id @default(uuid())
  userId          String
  problemId       String
  roundId         Int
  code            String
  language        String
  status          SubmissionStatus
  runtime         Int?
  memory          Int?
  testCasesPassed Int?
  executionCount  Int              @default(1)
  createdAt       DateTime         @default(now())
  problem         Problem          @relation(fields: [problemId], references: [id])
  round           Round            @relation(fields: [roundId], references: [roundNumber])
  user            User             @relation(fields: [userId], references: [id])
}

model Match {
  id        String   @id @default(uuid())
  playerAId String
  playerBId String
  winnerId  String?
  problemId String
  status    String
  timeLeft  Int?
  createdAt DateTime @default(now())
  playerA   User     @relation("PlayerAMatches", fields: [playerAId], references: [id])
  playerB   User     @relation("PlayerBMatches", fields: [playerBId], references: [id])
  winner    User?    @relation("WinnerMatches", fields: [winnerId], references: [id])
}

model LockedSolution {
  id         String   @id @default(uuid())
  userId     String
  questionId String
  createdAt  DateTime @default(now())
  problem    Problem  @relation(fields: [questionId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, questionId])
}

model HackAttempt {
  id          String     @id @default(uuid())
  hackerId    String
  targetId    String
  questionId  String
  customInput String
  status      HackStatus @default(PENDING_REVIEW)
  createdAt   DateTime   @default(now())
  hacker      User       @relation("HackerAttempts", fields: [hackerId], references: [id])
  problem     Problem    @relation(fields: [questionId], references: [id])
  target      User       @relation("TargetAttempts", fields: [targetId], references: [id])
}

enum Role {
  ADMIN
  PLAYER
}

enum Difficulty {
  R0
  R1_EASY
  R1_MEDIUM
  R1_HARD
  R2_BOUNTY
  R2_CHALLENGE
  R3
}

enum RoundStatus {
  LOCKED
  LOBBY
  IN_PROGRESS
  COMPLETED
}

enum Round2Role {
  ELITE
  CHALLENGER
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  COMPILATION_ERROR
  RUNTIME_ERROR
}

enum HackStatus {
  PENDING_REVIEW
  SUCCESSFUL
  FAILED
}
