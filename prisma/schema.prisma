datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  ADMIN
  PLAYER
}

model User {
  id         String   @id @default(uuid())
  username   String   @unique
  email      String   @unique
  role       Role     @default(PLAYER)
  badges     String[] @default([])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  matchesAsPlayerA Match[] @relation("PlayerAMatches")
  matchesAsPlayerB Match[] @relation("PlayerBMatches")
  matchesAsWinner  Match[] @relation("WinnerMatches")

  stats       Stats?
  submissions Submission[]
}

model Stats {
  id             String   @id @default(uuid())
  userId         String   @unique
  eloRating      Int      @default(0)
  gamesPlayed    Int      @default(0)
  totalTimeSpent Int      @default(0)
  problemsSolved Int      @default(0)
  winRate        Float    @default(0.0)
  streak         Int      @default(0)
  maxStreak      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User     @relation(fields: [userId], references: [id])
}

model Problem {
  id                String   @id @default(uuid())
  title             String   @unique
  description       String
  difficulty        Difficulty
  constraints       String[]
  hints             String[]
  boilerplate       Json
  functionSignatures Json
  sampleTestCases   Json
  hiddenTestCases   Json
  systemDesign      Json
  categories        Category[] @relation("ProblemCategories")
  avgTimeComplexity String
  avgSpaceComplexity String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  matches     Match[]      @relation("ProblemMatches")
  submissions Submission[]
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

model Category {
  id       String    @id @default(uuid())
  name     String    @unique
  problems Problem[] @relation("ProblemCategories")
}

model Match {
  id         String    @id @default(uuid())
  playerAId  String
  playerBId  String
  winnerId   String?
  duration   Int
  status     MatchStatus @default(ONGOING)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  playerA    User      @relation("PlayerAMatches", fields: [playerAId], references: [id])
  playerB    User      @relation("PlayerBMatches", fields: [playerBId], references: [id])
  winner     User?     @relation("WinnerMatches", fields: [winnerId], references: [id])
  problems   Problem[] @relation("ProblemMatches")
  submissions Submission[]
}

enum MatchStatus {
  ONGOING
  COMPLETED
  TIMEOUT
  ABANDONED
}

model Submission {
  id              String   @id @default(uuid())
  matchId         String?
  problemId       String
  playerId        String
  code            String
  language        String
  status          SubmissionStatus
  runtime         Int?
  memory          Int?
  testCasesPassed Int
  totalTestCases  Int
  isCheat         Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  match           Match?   @relation(fields: [matchId], references: [id])
  problem         Problem  @relation(fields: [problemId], references: [id])
  player          User     @relation(fields: [playerId], references: [id])
}

enum SubmissionStatus {
  PENDING
  ACCEPTED
  WRONG_ANSWER
  TIME_LIMIT_EXCEEDED
  COMPILATION_ERROR
  RUNTIME_ERROR
}